# WorkflowForge environment template
# Do not put secrets in this file.

WORKFLOWFORGE_APP_NAME=WorkflowForge
WORKFLOWFORGE_ENVIRONMENT=development
WORKFLOWFORGE_DEBUG=true
WORKFLOWFORGE_LOG_LEVEL=INFO
WORKFLOWFORGE_LOG_FORMAT=console

WORKFLOWFORGE_API_HOST=0.0.0.0
WORKFLOWFORGE_API_PORT=8000
WORKFLOWFORGE_API_V1_PREFIX=/api/v1
WORKFLOWFORGE_API_DOCS_ENABLED=true
WORKFLOWFORGE_CORS_ORIGINS=http://localhost:5173

# Docker host ports for local development.
WORKFLOWFORGE_POSTGRES_HOST_PORT=5432
WORKFLOWFORGE_REDIS_HOST_PORT=6379
WORKFLOWFORGE_MINIO_API_HOST_PORT=9000
WORKFLOWFORGE_MINIO_CONSOLE_HOST_PORT=9001
WORKFLOWFORGE_API_HOST_PORT=8000

# PostgreSQL container defaults for local development only.
POSTGRES_DB=workflowforge
POSTGRES_USER=workflowforge
POSTGRES_PASSWORD=workflowforge_dev

# WorkflowForge database access inside Docker Compose.
WORKFLOWFORGE_DATABASE_HOST=postgres
WORKFLOWFORGE_DATABASE_PORT=5432
WORKFLOWFORGE_DATABASE_NAME=workflowforge
WORKFLOWFORGE_DATABASE_USER=workflowforge
WORKFLOWFORGE_DATABASE_PASSWORD=workflowforge_dev
WORKFLOWFORGE_DATABASE_ECHO=false
WORKFLOWFORGE_DATABASE_POOL_SIZE=5
WORKFLOWFORGE_DATABASE_MAX_OVERFLOW=10
WORKFLOWFORGE_DATABASE_POOL_TIMEOUT_SECONDS=30

# Redis infrastructure for local development.
WORKFLOWFORGE_REDIS_HOST=redis
WORKFLOWFORGE_REDIS_PORT=6379

# MinIO local S3-compatible storage defaults.
MINIO_ROOT_USER=workflowforge
MINIO_ROOT_PASSWORD=workflowforge_dev_secret
WORKFLOWFORGE_S3_ENDPOINT_URL=http://minio:9000
WORKFLOWFORGE_S3_ACCESS_KEY=workflowforge
WORKFLOWFORGE_S3_SECRET_KEY=workflowforge_dev_secret
WORKFLOWFORGE_S3_BUCKET=workflowforge
WORKFLOWFORGE_S3_REGION=us-east-1
WORKFLOWFORGE_S3_USE_SSL=false
